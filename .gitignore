# --- Hugo 核心生成目录 ---
# 这里的目录由 hugo 命令动态生成，不需要上传
public/
resources/_gen/
assets/jsconfig.json
hugo_stats.json

# --- 编译与运行锁文件 ---
.hugo_build.lock
/tmp/

# --- 操作系统相关 (Windows/macOS 垃圾文件) ---
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride

# --- 编辑器与 IDE 配置 (针对你的开发环境) ---
# Vim 交换文件 (既然你习惯用 Vim，这非常重要)
*.swp
*.swo
.netrwhist
undo/

# VS Code / JetBrains
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- 敏感信息与日志 ---
# 如果你以后要在脚本里写 Cloudflare R2 的 API Key，记得存在 .env 里并排除
.env
.env.*
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- 依赖与模块缓存 ---
node_modules/
.hugo_build.lock